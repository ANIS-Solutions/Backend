{
  "name": "anis-backend",
  "version": "1.0.0",
  "description": "This is a backend for Anis project.",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=dev tsx --watch src/server.ts",
    "start": "NODE_ENV=production node dist/server.js",
    "build": "tsc && tsc-alias",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean:dist": "rm -rf dist",
    "clean:node": "rm -rf node_modules/ && pnpm install",
    "prepare": "husky",
    "tree": "tree -a -I 'node_modules|dist|.git|.husky|*.log|*.map|.env*|*.txt|*.md' --dirsfirst > tree.log"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "api",
    "backend"
  ],
  "author": "anis team",
  "license": "ISC",
  "packageManager": "pnpm@10.17.0",
  "dependencies": {
    "@types/nodemailer": "^7.0.4",
    "bcryptjs": "^3.0.3",
    "check-password-strength": "^3.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mjml": "^4.18.0",
    "mongoose": "^9.0.0",
    "morgan": "^1.10.1",
    "nodemailer": "^7.0.11",
    "phone": "^3.1.67",
    "uuid": "^13.0.0",
    "winston": "^3.18.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@commitlint/types": "^20.0.0",
    "@eslint/js": "^9.39.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mjml": "^4.7.4",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.10.1",
    "conventional-changelog-atom": "^5.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
