{
  "name": "anis-backend",
  "version": "1.0.1",
  "description": "This is a backend for Anis project.",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=dev tsx --watch src/server.ts",
    "dev:worker": "cross-env NODE_ENV=dev tsx --watch src/worker.ts",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "start:worker": "cross-env NODE_ENV=production node dist/worker.js",
    "build": "tsc && tsc-alias",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean:dist": "rm -rf dist",
    "clean:node": "rm -rf node_modules/ && pnpm install",
    "prepare": "husky",
    "tree": "tree -a -I 'node_modules|dist|_assets|coverage|*bak*|\\.*|\\.vscode|.git|.husky|*.log|*.map|.env*|*.txt|*.md' --dirsfirst > tree.log",
    "test": "cross-env NODE_ENV=test DATABASE_NAME=integration_test_anis DOTENV_CONFIG_DEBUG=false NODE_OPTIONS=--experimental-vm-modules jest --no-coverage"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "api",
    "backend"
  ],
  "contributors": [
    {
      "name": "Ahmed Abbas",
      "url": "https://github.com/3bbaas"
    },
    {
      "name": "Hassnaa Nageh",
      "url": "https://github.com/Hasnaa-Nageh"
    }
  ],
  "license": "ISC",
  "packageManager": "pnpm@10.17.0",
  "dependencies": {
    "@anis/shared": "link:../anis-shared",
    "@types/nodemailer": "^7.0.4",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.1",
    "check-password-strength": "^3.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jest-mock": "^30.2.0",
    "jsonwebtoken": "^9.0.2",
    "mjml": "^4.18.0",
    "mongoose": "^9.0.0",
    "morgan": "^1.10.1",
    "nodemailer": "^7.0.11",
    "phone": "^3.1.67",
    "pm2": "^6.0.14",
    "uuid": "^13.0.0",
    "winston": "^3.18.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@commitlint/types": "^20.0.0",
    "@eslint/js": "^9.39.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@jest/globals": "^30.2.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mjml": "^4.7.4",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.10.1",
    "@types/supertest": "^6.0.3",
    "conventional-changelog-atom": "^5.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jiti": "^2.6.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
