{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": false,
  // "todo-tree.highlights.defaultHighlight": {
  //   "icon": "alert",
  //   "type": "text",
  //   "foreground": "red",
  //   "background": "white",
  //   "opacity": 50,
  //   "iconColour": "blue"
  // },
  "todo-tree.filtering.excludeGlobs": [
    "vendor/**",
    "node_modules/**",
    "dist/**",
    "bower_components/**",
    "build/**",
    ".vscode/**",
    ".github/**",
    "_output/**",
    "*.min.*",
    "*.map"
  ],
  "todo-tree.general.tags": ["@todo", "REVIEW", "TODO", "FIXME"],
  "todo-tree.general.tagGroups": {
    "FIXME": ["FIXME", "FIXIT", "FIX"],
    "TODO": ["TODO", "todo", "ds"]
  },

  "todo-tree.highlights.customHighlight": {
    "TODO": {
      "icon": "alert",
      "type": "tag-and-comment",
      "foreground": "#d4d4d4",
      "iconColour": "#d06a56",
      "background": "#446d49",
      "fontWeight": "900",
      "opacity": 70
    },
    "REVIEW": {
      "foreground": "#212020",
      "background": "#87B0AB",
      "iconColour": "#95B1ED",
      "fontWeight": "900",
      "opacity": 70,
      "icon": "eye"
    },
    "FIXME": {
      "foreground": "#D4BA85",
      "iconColour": "#D49285",
      "background": "#4c5032",
      "type": "tag-and-comment",
      "fontWeight": "900",
      "opacity": 70
    }
  }
}
