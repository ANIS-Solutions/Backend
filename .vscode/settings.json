{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "typescript.implementationsCodeLens.enabled": true,
  "typescript.implementationsCodeLens.showOnAllClassMethods": true,
  "typescript.implementationsCodeLens.showOnInterfaceMethods": true,
  "javascript.referencesCodeLens.enabled": true,
  "javascript.referencesCodeLens.showOnAllFunctions": true,
  "typescript.referencesCodeLens.enabled": true,
  "typescript.referencesCodeLens.showOnAllFunctions": true,
  "editor.acceptSuggestionOnCommitCharacter": false,
  "files.eol": "\n",
  "todo-tree.filtering.excludeGlobs": [
    "vendor",
    "node_modules",
    "**/node_modules/*/**",
    "dist",
    "bower_components",
    "build",
    ".vscode",
    ".github",
    "_output",
    "*.min.*",
    "*.map"
  ],
  "todo-tree.general.tags": ["@todo", "REVIEW", "TODO", "FIXME"],
  "todo-tree.general.tagGroups": {
    "FIXME": ["FIXME", "FIXIT", "FIX"],
    "TODO": ["TODO", "todo"],
    "REVIEW": ["REVIEW", "review", "rev"]
  },

  "todo-tree.highlights.customHighlight": {
    "TODO": {
      "icon": "alert",
      "type": "tag-and-comment",
      "foreground": "#d4d4d4",
      "iconColour": "#d06a56",
      "background": "#446d49",
      "fontWeight": "900",
      "opacity": 70
    },
    "REVIEW": {
      // REVIEW: sdsd
      "icon": "eye",
      "type": "tag-and-comment",
      "foreground": "#0a9e8c",
      "background": "#213734",
      "iconColour": "#95B1ED",
      "fontWeight": "900",
      "opacity": 70
    },
    "FIXME": {
      "foreground": "#D4BA85",
      "iconColour": "#D49285",
      "background": "#4c5032",
      "type": "tag-and-comment",
      "fontWeight": "900",
      "opacity": 70
    }
  }
}
